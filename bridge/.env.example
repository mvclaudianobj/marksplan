MAP_URL=http://127.0.0.1:20320
PLANKA_URL=http://127.0.0.1:3000

# Autenticação fase 1: use preferencialmente cookie de sessão do Map.
# Exemplo: session=.eJx...
MAP_SESSION_COOKIE=

# Fallback opcional para cenários com chave central.
MAP_API_KEY=
MAP_AUTH_BEARER=

# Planka API direta
PLANKA_EMAIL=
PLANKA_USERNAME=
PLANKA_PASSWORD=
PLANKA_TOKEN=

MAP_TIMEOUT_SECONDS=15
PLANKA_MAP_ACTOR=markscode
PLANKA_MAP_HOST=planka
PLANKA_MAP_DEFAULT_TASK_STATUS=open
PLANKA_MAP_DEFAULT_TASK_PRIORITY=medium
PLANKA_MAP_DEFAULT_ASSIGNEE=markscode
PLANKA_MAP_DEFAULT_INBOX_LIST=BackLogs
PLANKA_MAP_DEFAULT_MODULE=geral
PLANKA_IMPORT_CONTAINER_NAME=Marks Imports
PLANKA_IMPORT_CONTAINER_BACKGROUND=forest
PLANKA_IMPORT_CREATE_MINIMAL_LISTS=1

# Endpoints do Map usados pelo importador Map -> Planka.
# Ajuste se a API local expuser caminhos diferentes.
MAP_PROJECTS_ENDPOINT=/api/map/v1/projects
MAP_TASKS_ENDPOINT_TEMPLATE=/api/map/v1/projects/{project_slug}/tasks

# Mapeamento explícito board_name -> project_slug.
# Use JSON para nomes com espaços e casos conhecidos de produção.
# Exemplo: {"Marks Plan":"ecosystem-marks","Board Secundário":"board-secundario"}
PLANKA_MAP_PROJECT_SLUG_MAP_JSON=

# Alternativa simples por pares. Aceita ';', ',' ou quebra de linha como separador.
# Exemplo: Marks Plan=ecosystem-marks;Board Secundário=board-secundario
PLANKA_MAP_PROJECT_SLUG_MAP=

# Alias opcional label -> module_slug para quando as labels do MarksPlan
# não coincidirem exatamente com os módulos existentes no Map.
# Exemplo JSON: {"planka":"integration","map":"integration"}
PLANKA_MAP_MODULE_SLUG_MAP_JSON=

# Alternativa simples por pares. Exemplo: planka=integration;map=integration
PLANKA_MAP_MODULE_SLUG_MAP=

# Receiver opcional local para automações/eventos externos.
PLANKA_MAP_RECEIVER_HOST=127.0.0.1
PLANKA_MAP_RECEIVER_PORT=8941
PLANKA_MAP_RECEIVER_SECRET_HEADER=X-Planka-Bridge-Secret
PLANKA_MAP_RECEIVER_SECRET=
